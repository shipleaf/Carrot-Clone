generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Store {
  id                    Int          @id @default(autoincrement())
  name                  String
  category              String
  lat                   Float
  lng                   Float
  address               String
  phone                 String
  instagramUrl          String?
  description           String?
  ownerName             String
  ownerProfileImageUrl  String?
  followerCount         Int          @default(0)
  createdAt             DateTime     @default(now())

  images      StoreImage[]
  hours       StoreHours[]
  menuItems   MenuItem[]
  reviews     Review[]
  news        StoreNews[]
  coupons     Coupon[]
  inventories StoreInventory[]
}

model TrendingItem {
  id          Int              @id @default(autoincrement())
  slug        String           @unique
  name        String
  emoji       String
  description String?
  isActive    Boolean          @default(true)
  startedAt   DateTime         @default(now())
  endedAt     DateTime?

  inventories StoreInventory[]
}

model StoreInventory {
  id             Int          @id @default(autoincrement())
  storeId        Int
  trendingItemId Int
  quantity       Int          @default(0)
  note           String?
  updatedAt      DateTime     @updatedAt

  store        Store        @relation(fields: [storeId], references: [id])
  trendingItem TrendingItem @relation(fields: [trendingItemId], references: [id])

  @@unique([storeId, trendingItemId])
}

model StoreImage {
  id      Int    @id @default(autoincrement())
  storeId Int
  url     String
  order   Int

  store Store @relation(fields: [storeId], references: [id])
}

model StoreHours {
  id        Int     @id @default(autoincrement())
  storeId   Int
  dayOfWeek Int
  openTime  String
  closeTime String
  isClosed  Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id])
}

model MenuItem {
  id          Int     @id @default(autoincrement())
  storeId     Int
  name        String
  price       Int
  description String?
  imageUrl    String?

  store Store @relation(fields: [storeId], references: [id])
}

model Review {
  id                   Int      @id @default(autoincrement())
  storeId              Int
  userId               String
  userProfileImageUrl  String?
  rating               Int
  content              String
  likeCount            Int      @default(0)
  createdAt            DateTime @default(now())

  store  Store         @relation(fields: [storeId], references: [id])
  images ReviewImage[]
}

model ReviewImage {
  id       Int    @id @default(autoincrement())
  reviewId Int
  url      String

  review Review @relation(fields: [reviewId], references: [id])
}

model StoreNews {
  id        Int      @id @default(autoincrement())
  storeId   Int
  content   String
  likeCount Int      @default(0)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])
}

model Coupon {
  id          Int       @id @default(autoincrement())
  storeId     Int
  title       String
  description String?
  imageUrl    String?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  store         Store          @relation(fields: [storeId], references: [id])
  treasureSpots TreasureSpot[]
  userCoupons   UserCoupon[]
}

model TreasureSpot {
  id        Int      @id @default(autoincrement())
  lat       Float
  lng       Float
  couponId  Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
}

model UserCoupon {
  id        Int       @id @default(autoincrement())
  userId    String
  couponId  Int
  claimedAt DateTime  @default(now())
  usedAt    DateTime?

  coupon Coupon @relation(fields: [couponId], references: [id])

  @@unique([userId, couponId])
}
